# Your OpenRouter API key goes here. You can get it from https://openrouter.ai/dashboard
OPENROUTER_API_KEY=your_openrouter_key_here
# Your TMDB API key goes here. You can get it from https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_key_here

# Full path to the directory where your videos are stored. This should match the VIDEO_DIR in your backend configuration.
# Example: VIDEO_DIR=/home/user/videos
VIDEO_DIR=/path/to/videos