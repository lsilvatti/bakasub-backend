meta {
  name: Update Config
  type: http
  seq: 2
}

put {
  url: http://localhost:8080/api/v1/config
  body: json
  auth: none
}

body:json {
  {
    "default_model": "openai/gpt-4o-mini",
    "default_preset": "movie",
    "default_language": "pt-BR",
    "remove_sdh_default": true,
    "video_timeout_minutes": 20,
    "log_retention_days": 30
  }
}